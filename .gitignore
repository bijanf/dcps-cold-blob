credentials.json
token.json
secrets/
.aws/
# Local CEDA credential install script - NEVER commit
add_ceda_to_netrc.sh
*.netrc
.netrc

# Background-process logs (may contain Pangeo URLs or auth artefacts)
logs/

# External-drive symlink and large external dataset mirrors
data/external_drive/

# P6 PIK bundle staging area (canonical files copied into data/external/p6/)
p6_results/
p6_bundle.tar.gz

# Sharable manuscript bundles built by `zip -r ... manuscript/...`
manuscript-bundle-*.zip
manuscript-bundle-README.md

# Working notes, scratch markdown, and conversation transcripts.
# Generic patterns — keep working notes out of public history.
*conversation*.md
*session*.md
*transcript*.md
*chat*.md
*handoff*.md
*notes*.md
*scratch*.md
*draft*.md
.local-config/
.local-tools/
*-output.xml

# Local workspace symlink to the manuscript working tree (when present).
# Figure-writing scripts resolve `manuscript/figs/...` through this
# symlink; the link itself is a per-machine convenience and is never
# tracked in this repo.
/manuscript
/manuscript/

